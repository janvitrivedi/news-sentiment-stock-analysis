# Ignore data files
data/raw/

# Large data files
raw_analyst_ratings.csv
*.csv


# Ignore environment variables
.env

# Ignore virtual environment
venv/
.venv/

# Ignore Python cache
__pycache__/
*.pyc

cat > .gitignore << 'EOF'
# Large data files
raw_analyst_ratings.csv
*.csv

# Mac system files
.DS_Store
src/.DS_Store

# CSV files (generated by pipeline)
*.csv
EOF